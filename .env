# MinIO Server 
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# MinIO Client (ACCESS_KEY=MINIO_ROOT_USER + SECRET_KEY=MINIO_ROOT_PASSWORD)
# The client can only use credentials that the server recognizes.
ENDPOINT=http://minio:9000
ACCESS_KEY=minioadmin
SECRET_KEY=minioadmin
USE_SSL=False
REGION=eu-central-1
BUCKET_NAME=geo-bucket