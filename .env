# MinIO Server 
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO Client (ACCESS_KEY=MINIO_ROOT_USER + SECRET_KEY=MINIO_ROOT_PASSWORD)
# The client can only use credentials that the server recognizes.
ENDPOINT=http://minio:9000
ACCESS_KEY=minioadmin
SECRET_KEY=minioadmin
USE_SSL=False
REGION=eu-central-1

BUCKET_NAME=geo-bucket

# TODO: later - INPUT_FILE_PATH -> CLI parameter 
INPUT_DIR=/app/data/input
OUTPUT_DIR=/app/data/output

# OUTPUT_PREFIX=berlin_

# 0 = no limit (needed for large GeoJSON files)
# OGR_GEOJSON_MAX_OBJ_SIZE=500
OGR_GEOJSON_MAX_OBJ_SIZE=0

# config: geoparquet (geopandas)
# zstd, brotli, gzip
GEOPANDAS_PARQUET_COMPRESSION=snappy

# config: geoparquet (ogr)
OGR_PARQUET_COMPRESSION=snappy

# config: tippecanoe 
# do not use max value > 12 for large dataset 
TILE_ZOOM_MIN=0
TILE_ZOOM_MAX=10
TIPPECANOE_READ_PARALLEL=true
TIPPECANOE_DROP_DENSE=true